# Required for Base Sepolia or another non-default network.
# Primary RPC endpoint (used if RPC_URLS not set). Base Sepolia chainId is 84532.
RPC_URL=https://sepolia.base.org

# Optional: Comma-separated list of RPC endpoints for failover
RPC_URLS=https://base-sepolia-rpc.publicnode.com,https://public.stackup.sh/api/v1/node/base-sepolia

# Use a dedicated low-balance hot wallet for the running node. Never use a main holding wallet.
# Runtime requires OPERATOR_PRIVATE_KEY. DEPLOYER_PRIVATE_KEY is deploy-only and must not be set in the operator process.
OPERATOR_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=

VENOM_REGISTRY_ADDRESS=
PILOT_ESCROW_ADDRESS=

# Required runtime guardrails. USE_TEST_PAYLOAD must be explicitly true or false.
# mainnet + USE_TEST_PAYLOAD=true refuses to start.
VENOM_RUNTIME_MODE=testnet
USE_TEST_PAYLOAD=false

# Unified Etherscan V2 API key for verification across supported chains.
# Create one at https://etherscan.io/apis.
ETHERSCAN_API_KEY=
REPORT_GAS=false

# Redis connection settings (used when running outside Docker)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
DASHBOARD_REDIS_HOST=127.0.0.1
DASHBOARD_REDIS_PORT=6379
DASHBOARD_REDIS_USERNAME=venom_dash

# Optional: Redis authentication (for production deployments).
# The bundled Redis ACL disables the default user; host-side node tools should authenticate as venom_node.
REDIS_USERNAME=venom_node
REDIS_PASSWORD=
REDIS_TLS=false

# Docker Compose sets this automatically; override for local development if needed.
ML_SERVICE_URL=http://127.0.0.1:8000/evaluate

# ML Service API Key (required for testnet/mainnet health and evaluate requests).
# Replace this sentinel before running Docker Compose in testnet/mainnet mode.
ML_SERVICE_API_KEY=replace-me-with-a-random-32-byte-hex-value

# Optional IPFS gateway list for real payload fetching experiments.
IPFS_GATEWAYS=https://ipfs.io/ipfs,https://dweb.link/ipfs,https://gateway.pinata.cloud/ipfs
MAX_PAYLOAD_BYTES=51200
FETCH_TIMEOUT_MS=15000
ML_TIMEOUT_MS=30000
WORKER_CONCURRENCY=4
PROCESSED_CAMPAIGN_TTL_SECONDS=86400
P2P_ORACLE_REFRESH_MS=60000
P2P_PENDING_CAMPAIGN_TTL_MS=14400000
P2P_PENDING_CAMPAIGN_GC_MS=60000
P2P_MAX_PENDING_CAMPAIGNS=1000
# Time window for the signer-derived round-0 leader before rotating to the next score signer.
P2P_LEADER_TIMEOUT_MS=15000

# P2P rate limiting
P2P_MAX_MESSAGE_AGE_MS=300000
P2P_MAX_MESSAGES_PER_WINDOW=100
P2P_RATE_WINDOW_MS=10000

# IPFS concurrent fallback
IPFS_CONCURRENT_FETCH=3
IPFS_GATEWAY_TIMEOUT=8000

# Score range bounds
SCORE_MAX=100
SCORE_MIN=0

# ML service request limits. Byte limit mirrors MAX_PAYLOAD_BYTES for non-ASCII payloads.
MAX_EVALUATE_BYTES=51200
MAX_EVALUATE_TEXT_LENGTH=51200

# Live preflight probes. Use a small public test CID and the SHA-256 digest of
# the exact bytes expected from that CID.
PREFLIGHT_IPFS_CID=
PREFLIGHT_IPFS_SHA256=
PREFLIGHT_IPFS_TIMEOUT_MS=8000
PREFLIGHT_REFERENCE_ANSWER=
PREFLIGHT_BALANCE_BUFFER_ETH=0.02
PREFLIGHT_CLOSE_GAS_LIMIT=500000
# Optional external service for PUBLIC_MULTIADDR dial-back checks. If unset,
# live preflight records a warning rather than failing.
PUBLIC_MULTIADDR=
# Solo non-production escape hatch for machines without public P2P reachability.
# Never use this for production pilots.
VENOM_ALLOW_PRIVATE_MULTIADDR=false
PREFLIGHT_P2P_DIALBACK_URL=
PREFLIGHT_REQUIRE_P2P_DIALBACK=false

# When no Redis producer cursor exists yet, scan this many recent blocks.
PRODUCER_SCAN_LOOKBACK_BLOCKS=10000
# Maximum block span per CampaignFunded queryFilter call.
PRODUCER_SCAN_CHUNK_BLOCKS=1000
# Re-scan this many already-scanned blocks to tolerate small L2 reorgs.
PRODUCER_REORG_LOOKBACK_BLOCKS=10

# closeCampaign transaction safety
CLOSE_CONFIRMATIONS=3
CLOSE_GAS_LIMIT=
CLOSE_MAX_FEE_GWEI=
CLOSE_MAX_PRIORITY_FEE_GWEI=

# Redis queue name (for multi-node deployments)
QUEUE_NAME=venom-campaigns

# Health endpoint
HEALTH_PORT=3000
HEALTH_HOST=127.0.0.1

# Testnet/demo-only fallback until real payload fetching is complete.
