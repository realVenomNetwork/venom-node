{
  "name": "venom-network",
  "version": "1.0.1",
  "private": true,
  "description": "Decentralized ML-gated oracle network with governance and charitable redirection modules",
  "main": "register_and_start.js",
  "bin": {
    "venom": "./cli/venom.js"
  },
  "scripts": {
    "start": "node register_and_start.js",
    "venom": "node cli/venom.js",
    "doctor": "node cli/venom.js doctor",
    "init": "node cli/venom.js init",
    "status": "node cli/venom.js status",
    "venom:card": "node cli/venom.js card",
    "venom:postcard": "node cli/venom.js postcard",
    "roadmap:check": "node scripts/roadmap-check.js",
    "dashboard": "node dashboard/server.js",
    "dev": "nodemon register_and_start.js",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "lint:js": "node scripts/check-js.js",
    "coverage": "hardhat coverage",
    "audit:prod": "npm audit --omit=dev --audit-level=critical",
    "pilot:smoke-test": "node scripts/pilot/smoke-test.js",
    "demo:pilot": "node scripts/pilot/smoke-test.js --scenario=all-agree",
    "deploy:phase4": "hardhat run scripts/deploy_phase4.js --network base-sepolia",
    "deploy:tithe": "hardhat run scripts/governance/deploy_tithing.cjs --network base-sepolia",
    "demo:governance": "hardhat run scripts/governance/demo-full-flow.js --network hardhat",
    "docker:up": "docker compose up -d --build"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.0",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@libp2p/identify": "^4.1.3",
    "@libp2p/mplex": "^11.0.0",
    "@libp2p/tcp": "^10.0.0",
    "@multiformats/multiaddr": "^12.3.0",
    "@openzeppelin/contracts": "^5.6.1",
    "bullmq": "^5.76.2",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "ioredis": "^5.10.1",
    "libp2p": "^2.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "nodemon": "^3.1.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
